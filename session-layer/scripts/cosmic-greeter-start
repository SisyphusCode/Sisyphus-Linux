#!/usr/bin/env bash
# Forge overlay — log greeter session output; pick the panel GPU on hybrid laptops.
LOG=/var/lib/forge/cosmic-greeter-session.log
mkdir -p /run/cosmic-greeter "$(dirname "$LOG")"
exec >>"$LOG" 2>&1
echo "=== $(date -Is 2>/dev/null || date) cosmic-greeter-start uid=$(id -u) ==="
rm -rf /run/cosmic-greeter/cosmic/com.system76.CosmicSettingsDaemon/v1/* 2>/dev/null

uid=$(id -u)
greeter_home="/var/lib/cosmic-greeter"
export RUST_BACKTRACE=1
export RUST_LOG="${RUST_LOG:-cosmic_comp=debug,cosmic_greeter=debug,winit=info}"
unset FLATPAK_ID HOST_XDG_CONFIG_HOME HOST_XDG_DATA_HOME HOST_XDG_STATE_HOME
export HOME="$greeter_home"
export XDG_CONFIG_HOME="${greeter_home}/.config"
export XDG_STATE_HOME="${greeter_home}/.local/state"
export XDG_DATA_HOME="${greeter_home}/.local/share"
export XDG_RUNTIME_DIR="/run/user/${uid}"
mkdir -p "$XDG_CONFIG_HOME" "$XDG_STATE_HOME" "$XDG_DATA_HOME" "$XDG_RUNTIME_DIR"
mkdir -p /run/cosmic-greeter/cosmic 2>/dev/null || true
chmod 0700 "$XDG_RUNTIME_DIR" 2>/dev/null || true
export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=${XDG_RUNTIME_DIR}/bus}"
echo "cosmic-greeter-start: HOME=${HOME} XDG_CONFIG_HOME=${XDG_CONFIG_HOME} XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR}"
export XDG_SESSION_TYPE=wayland
export XDG_SESSION_CLASS=greeter
export XDG_CURRENT_DESKTOP=COSMIC
export XDG_SEAT=seat0
export XDG_VTNR=1
export GDK_BACKEND=wayland
export WLR_NO_HARDWARE_CURSORS=1

if [[ -f /run/cosmic-greeter/environment ]]; then
  # shellcheck disable=SC1091
  . /run/cosmic-greeter/environment
  echo "cosmic-greeter-start: loaded /run/cosmic-greeter/environment"
fi
if [[ -S /run/seatd.sock ]]; then
  export LIBSEAT_BACKEND=seatd
  export SEATD_SOCK="${SEATD_SOCK:-/run/seatd.sock}"
else
  export LIBSEAT_BACKEND="${LIBSEAT_BACKEND:-logind}"
fi

if [[ -z "${WLR_DRM_DEVICES:-}" ]]; then
  for entry in /sys/class/drm/card*-*; do
    [[ -d "$entry" && -f "$entry/status" ]] || continue
    [[ "$(basename "$entry")" =~ -[0-9]+$ ]] || continue
    if [[ "$(cat "$entry/status" 2>/dev/null)" == "connected" ]]; then
      idx="${entry#/sys/class/drm/card}"
      idx="${idx%%-*}"
      export WLR_DRM_DEVICES="/dev/dri/card${idx}"
      break
    fi
  done
fi

pick_openable_drm() {
  for card in "$@"; do
    [[ -c "$card" ]] || continue
    if exec 9<>"$card" 2>/dev/null; then
      exec 9>&-
      echo "$card"
      return 0
    fi
  done
  return 1
}

first_openable=""
if [[ -n "${WLR_DRM_DEVICES:-}" ]]; then
  for card in $(printf '%s' "$WLR_DRM_DEVICES" | tr ':' ' '); do
    first_openable="$(pick_openable_drm "$card")" && break
  done
fi
if [[ -z "$first_openable" ]]; then
  for card in /dev/dri/card[0-9]*; do
    first_openable="$(pick_openable_drm "$card")" && break
  done
fi
export WLR_DRM_DEVICES="${first_openable:-/dev/dri/card0}"
export WLR_NO_HARDWARE_CURSORS="${WLR_NO_HARDWARE_CURSORS:-1}"

is_virtualized() {
  if command -v systemd-detect-virt >/dev/null 2>&1; then
    systemd-detect-virt --quiet && return 0
  fi
  grep -q 'hypervisor' /proc/cpuinfo 2>/dev/null && return 0
  for hint in /sys/class/dmi/id/product_name /sys/class/dmi/id/sys_vendor; do
    [[ -r "$hint" ]] || continue
    if grep -qiE 'kvm|qemu|vmware|virtualbox|xen|hyper-v|bhyve' "$hint"; then
      return 0
    fi
  done
  return 1
}

if is_virtualized; then
  # VMs are more stable with software rendering; seatd still brokers DRM when available.
  [[ -c /dev/dri/card0 ]] && export WLR_DRM_DEVICES=/dev/dri/card0
  export WLR_RENDERER="${WLR_RENDERER:-pixman}"
fi

echo "cosmic-greeter-start: COSMIC_BACKEND=${COSMIC_BACKEND:-auto} WLR_DRM_DEVICES=${WLR_DRM_DEVICES:-unset} LIBSEAT_BACKEND=${LIBSEAT_BACKEND:-unset} SEATD_SOCK=${SEATD_SOCK:-unset}"

for _ in $(seq 1 50); do
  [[ -S "${XDG_RUNTIME_DIR}/bus" ]] && break
  sleep 0.1
done
if command -v cosmic-settings-daemon >/dev/null 2>&1 && [[ -S "${XDG_RUNTIME_DIR}/bus" ]]; then
  if ! busctl --address="$DBUS_SESSION_BUS_ADDRESS" status com.system76.CosmicSettingsDaemon >/dev/null 2>&1; then
    cosmic-settings-daemon &
    echo "cosmic-greeter-start: launched cosmic-settings-daemon pid=$!"
  fi
fi

greetd_ipc_pid=""
cleanup_greetd_ipc() {
  if [[ -n "${greetd_ipc_pid:-}" ]]; then
    kill "$greetd_ipc_pid" 2>/dev/null || true
    wait "$greetd_ipc_pid" 2>/dev/null || true
  fi
}
trap cleanup_greetd_ipc EXIT

export GREETD_SOCK="${GREETD_SOCK:-${XDG_RUNTIME_DIR}/forge-greetd.sock}"
export FORGE_GREETD_IPC_LOG="$LOG"
if [[ -n "${GREETD_SOCK:-}" && "${GREETD_SOCK}" != "${XDG_RUNTIME_DIR}/forge-greetd.sock" ]]; then
  echo "cosmic-greeter-start: using existing GREETD_SOCK=$GREETD_SOCK"
elif [[ -x /usr/libexec/forge/forge-greetd-ipc.py ]]; then
  rm -f "$GREETD_SOCK" 2>/dev/null || true
  /usr/libexec/forge/forge-greetd-ipc.py "$GREETD_SOCK" &
  greetd_ipc_pid=$!
  for _ in $(seq 1 50); do
    [[ -S "$GREETD_SOCK" ]] && break
    sleep 0.1
  done
  echo "cosmic-greeter-start: GREETD_SOCK=$GREETD_SOCK forge-greetd-ipc pid=$greetd_ipc_pid"
else
  echo "cosmic-greeter-start: /usr/libexec/forge/forge-greetd-ipc.py missing"
fi

append_candidate() {
  local card="$1"
  [[ -n "$card" && -c "$card" ]] || return 0
  case " ${DRM_CANDIDATES:-} " in
    *" ${card} "*) ;;
    *) DRM_CANDIDATES="${DRM_CANDIDATES:-} ${card}" ;;
  esac
}

if [[ -n "${WLR_DRM_DEVICES:-}" ]]; then
  for card in $(printf '%s' "$WLR_DRM_DEVICES" | tr ':' ' '); do
    append_candidate "$card"
  done
fi
for card in /dev/dri/card[0-9]*; do
  append_candidate "$card"
done

for card in ${DRM_CANDIDATES:-}; do
  export WLR_DRM_DEVICES="$card"
  echo "cosmic-greeter-start: trying WLR_DRM_DEVICES=$WLR_DRM_DEVICES"
  start_ts="$(date +%s)"
  cosmic-comp cosmic-greeter
  rc=$?
  end_ts="$(date +%s)"
  elapsed=$((end_ts - start_ts))
  echo "cosmic-greeter-start: cosmic-comp exited rc=$rc after ${elapsed}s on $card"
  if (( rc == 0 || elapsed >= 15 )); then
    exit "$rc"
  fi
done

echo "cosmic-greeter-start: no usable DRM device found"
exit 1